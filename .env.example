# Public browser-safe values. These are allowed to be exposed in the Vite bundle.
VITE_APP_URL="http://localhost:3000"
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Server-only values. NEVER prefix these with VITE_ and NEVER use them in src/ browser code.
# Use only in Vercel API functions, Supabase Edge Functions, or other backend code.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY_SERVER_ONLY"
STUDENT_ID_PEPPER="GENERATE_A_LONG_RANDOM_SECRET_AT_LEAST_32_BYTES"
APP_URL="http://localhost:3000"

# Optional AI grading. Server-only. Never expose to the browser.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_SERVER_ONLY"
